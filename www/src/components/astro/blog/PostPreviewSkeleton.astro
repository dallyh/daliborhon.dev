<script is:inline>
	function removeSkeletonOnIntersection() {
		const images = document.querySelectorAll("figure.skeleton");

		const observer = new IntersectionObserver((entries, observer) => {
			for (const entry of entries) {
				if (entry.isIntersecting) {
					const imgDiv = entry.target;
					const i = imgDiv.querySelector("img");
					if (!i) return;

					if (i.complete) {
						imgDiv.classList.remove("skeleton");
						observer.unobserve(imgDiv);
					} else {
						i.onload = () => {
							imgDiv.classList.remove("skeleton");
							observer.unobserve(imgDiv);
						};
						i.onerror = () => {
							console.error("Image failed to load:", i.src);
						};
					}
				}
			}
		});

		for (const img of images) {
			observer.observe(img);
		}
	}

	// first load
	document.addEventListener("DOMContentLoaded", removeSkeletonOnIntersection);

	document.addEventListener("swup:enable", () => {
		swup.hooks.on("page:view", () => {
			removeSkeletonOnIntersection();
		});
	});
</script>
