---
import { Logger } from "@utils"
import { UPTIME_API_TOKEN } from "astro:env/server";
import { siteConfig } from "@site-config";


type Status = "up" | "down" | "failed" | undefined;

const cls = {
	up: "status-success",
	down: "status-error",
	failed: "status-error",
};

const fetchStatus = async (): Promise<Status> => {
	try {
		const res = await fetch(
			`https://uptime.betterstack.com/api/v2/monitors/${siteConfig.monitorId}`,
			{
				headers: {
					Authorization: `Bearer ${UPTIME_API_TOKEN}`,
					Accept: "application/json",
				},
			},
		);

		if (!res.ok) {
			// biome-ignore lint: logs locally to server
			console.error("[UptimeStatus] BetterStack request failed", {
				status: res.status,
				contentType: res.headers.get("content-type"),
				body: (await res.text()).slice(0, 500),
			});

			return "down";
		}

		const data = await res.json();

		return data?.data?.attributes?.status ?? "down";
	} catch (error) {
		// biome-ignore lint: logs locally to server
		console.error("[UptimeStatus] BetterStack request error", error);
		return "down";
	}
};

const status = await fetchStatus();
---

<a class="inline-grid *:[grid-area:1/1]" target="_blank" href="https://status.daliborhon.dev">
	<div class={`status rounded-full ${cls[status ?? "down"]} animate-ping`}></div>
	<div class={`status rounded-full ${cls[status ?? "down"]}`}></div>
</a>
