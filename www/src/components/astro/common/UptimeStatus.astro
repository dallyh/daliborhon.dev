---
import { Logger } from "@utils"

const logger = new Logger("UptimeStatus");

type Status = "up" | "down" | undefined;

const cls = {
	up: "status-success",
	down: "status-error",
};

const fetchStatus = async (): Promise<Status> => {
	const url = new URL("/api/bs-status", Astro.url);
	logger.info(`Fetching status from: ${url.toString()}`);
	const res = await fetch(url, {
		headers: {
			"User-Agent": "dalibor-runtime/1.0 (+https://daliborhon.dev)",
			Accept: "application/json",
		},
	});
	const text = await res.text();

	try {
		const data = JSON.parse(text);
		return data.status;
	} catch {
		const error = {
			status: res.status,
			contentType: res.headers.get("content-type"),
			body: text.slice(0, 500),
		};
		logger.error(`Non-JSON response from bs-status: ${JSON.stringify(error, null, 4)}`);
		return "down";
	}
};

const status = await fetchStatus();
---

<a class="inline-grid *:[grid-area:1/1]" target="_blank" href="https://status.daliborhon.dev">
	<div class={`status rounded-full ${cls[status ?? "down"]} animate-ping`}></div>
	<div class={`status rounded-full ${cls[status ?? "down"]}`}></div>
</a>
